# ─── WhatsApp Cloud API ───────────────────────────────────────────
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxx          # Token de acceso del sistema
PHONE_NUMBER_ID=123456789                # Meta → WhatsApp → API Setup
VERIFY_TOKEN=reservbot_secret_2026       # Token que tú inventas, igual al de Meta
APP_SECRET=abc123def456ghi789            # Meta → App Settings → Basic → App Secret

# ─── Anthropic ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# ─── Google Calendar ──────────────────────────────────────────────
GOOGLE_CREDENTIALS_JSON=./credentials/service_account.json
GOOGLE_CALENDAR_ID=primary               # o el ID del calendario de la barbería

# ─── State Manager ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0       # dejar vacío para usar SQLite local

# ─── App ──────────────────────────────────────────────────────────
APP_ENV=development                      # development | production
LOG_LEVEL=INFO
